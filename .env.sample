DATABASE_URL=postgres://postgres:postgres@localhost:5432/fake_email
DOMAIN=fake-email.site
HTTP_HOST=0.0.0.0
HTTP_PORT=3001
SMTP_HOST=0.0.0.0
# Local dev: use 2525 (no root). Match swaks: --port 2525. Production often uses 25.
SMTP_PORT=2525
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Next.js UI (`ui/`): leave NEXT_PUBLIC_API_URL unset so the app calls same-origin `/api/*`
# and Next proxies to http-server (avoids CORS). Optional override for `next dev` / `next build`:
# BACKEND_INTERNAL_URL=http://127.0.0.1:3001
# Set NEXT_PUBLIC_API_URL only when the UI must call the API on another origin and the API sends CORS headers.
